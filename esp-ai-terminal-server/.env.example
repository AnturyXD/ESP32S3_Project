APP_NAME=esp-ai-terminal-server
APP_VERSION=0.1.0
APP_STAGE=V0.6

# S0.4 默认只绑定本机回环地址，避免误暴露到公网。
APP_HOST=127.0.0.1
APP_PORT=18080
LOG_LEVEL=INFO

# V0.6 开始只在服务器侧接入火山 ASR 自测，设备端仍不上传音频。
AI_PROVIDER=placeholder

# S0.4 设备接口会读取本字段并校验 X-Device-Token。
# CHANGE_ME 只表示未配置；真实值必须写入服务器本地 .env，不能提交仓库。
DEVICE_SHARED_SECRET=CHANGE_ME

# 火山 ASR 配置。真实 ASR_API_KEY 只能写入服务器本地 .env，不能提交仓库。
# 当前单设备调试使用小时版资源，固定 16kHz / 16bit / mono PCM，并按 200ms 分包。
ASR_PROVIDER=volcengine
ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
ASR_API_KEY=
ASR_APP_KEY=
ASR_ACCESS_KEY=
ASR_RESOURCE_ID=volc.bigasr.sauc.duration
ASR_AUDIO_FORMAT=pcm
ASR_SAMPLE_RATE=16000
ASR_BITS=16
ASR_CHANNELS=1
ASR_PACKET_MS=200

# LLM / TTS 仍然只是占位，本轮不实现真实调用。
LLM_PROVIDER=volcengine_ark
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=

TTS_PROVIDER=volcengine
TTS_MODEL=seed-tts-2.0
TTS_API_KEY=
TTS_VOICE_TYPE=

