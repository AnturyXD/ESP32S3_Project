APP_NAME=esp-ai-terminal-server
APP_VERSION=0.1.0
APP_STAGE=V0.8

# S0.4 默认只绑定本机回环地址，避免误暴露到公网。
APP_HOST=127.0.0.1
APP_PORT=18080
LOG_LEVEL=INFO

# V0.8 当前服务器代理 ASR / LLM / TTS，TTS 只返回 ESP32 可播放的 PCM/WAV PCM。
AI_PROVIDER=placeholder

# S0.4 设备接口会读取本字段并校验 X-Device-Token。
# CHANGE_ME 只表示未配置；真实值必须写入服务器本地 .env，不能提交仓库。
DEVICE_SHARED_SECRET=CHANGE_ME

# 火山 ASR 配置。真实 ASR_API_KEY 只能写入服务器本地 .env，不能提交仓库。
# 当前单设备调试使用小时版资源，固定 16kHz / 16bit / mono PCM，并按 200ms 分包。
ASR_PROVIDER=volcengine
ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
ASR_API_KEY=
ASR_APP_KEY=
ASR_ACCESS_KEY=
ASR_RESOURCE_ID=volc.bigasr.sauc.duration
ASR_AUDIO_FORMAT=pcm
ASR_SAMPLE_RATE=16000
ASR_BITS=16
ASR_CHANNELS=1
ASR_PACKET_MS=200

# V0.7 火山方舟 LLM 文本代理配置。
# ARK_API_KEY 必须留空；真实 Key 只允许写入服务器本地 .env。
LLM_PROVIDER=volcengine_ark
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_INPUT_CHARS=1000
LLM_MAX_OUTPUT_TOKENS=512

# V0.8 火山 TTS 代理配置。真实密钥和音色只允许写入服务器本地 .env。
# TTS_WS_URL 历史字段名保留；V0.8 使用 HTTP Chunked 接口，留空时使用官方默认 endpoint。
TTS_PROVIDER=volcengine
TTS_MODEL=seed-tts-2.0
TTS_API_VERSION=v3
TTS_WS_URL=
TTS_APP_ID=
TTS_ACCESS_TOKEN=
TTS_API_KEY=
TTS_CLUSTER=
TTS_RESOURCE_ID=seed-tts-2.0
TTS_VOICE_TYPE=
TTS_AUDIO_FORMAT=pcm
TTS_SAMPLE_RATE=16000
TTS_BITS=16
TTS_CHANNELS=1
TTS_MAX_TEXT_CHARS=300
TTS_TIMEOUT_SECONDS=30

