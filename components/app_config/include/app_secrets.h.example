#pragma once

/*
 * 本地真实配置模板。
 *
 * 使用方式：
 * 1. 复制本文件为 app_secrets.h
 * 2. 填写本机 Wi-Fi、服务器地址和设备共享密钥
 * 3. 不要提交 app_secrets.h，它已经在 .gitignore 中被忽略
 */

#define WIFI_SSID "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

/*
 * S0.4 设备访问服务器配置。
 * 当前服务器默认只监听 127.0.0.1:18080，ESP32 不能访问该地址。
 * 如果短期调试公网端口，请先阅读 esp-ai-terminal-server/README.md。
 */
#define CLOUD_SERVER_BASE_URL "http://YOUR_SERVER_HOST_OR_IP:18080"
#define DEVICE_ID "esp32s3-dev-001"
#define DEVICE_SHARED_SECRET "YOUR_DEVICE_SHARED_SECRET"

/* V0.6 ASR 通过自建服务器 WebSocket 代理，不在 ESP32 保存火山 ASR 密钥。 */
#define CLOUD_ASR_WS_PATH "/ws/esp-ai-terminal/asr"
#define AI_ASR_MAX_SECONDS 15
#define AI_ASR_PACKET_MS 200

#define DOUBAO_API_KEY "YOUR_DOUBAO_API_KEY"
#define DOUBAO_ASR_MODEL "YOUR_ASR_MODEL"
#define DOUBAO_LLM_MODEL "YOUR_LLM_MODEL"
#define DOUBAO_TTS_MODEL "YOUR_TTS_MODEL"
#define DOUBAO_TTS_VOICE "YOUR_TTS_VOICE"

